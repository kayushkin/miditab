{
  "name": "miditab",
  "version": "0.1.0",
  "description": "Convert MIDI files to guitar tablature (ASCII).",
  "license": "MIT",
  "author": "Slava Kayushkin",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test test/*.test.mjs",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "keywords": ["midi", "guitar", "tab", "tablature", "music"]
}
